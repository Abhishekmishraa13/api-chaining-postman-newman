  "item": [
    {
      "name": "API 1 — Login",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "// Convert response into JSON",
              "let response = pm.response.json();",
              "",
              "// Save access token",
              "pm.environment.set(\"token\", response.accessToken);",
              "",
              "// Save user ID",
              "pm.environment.set(\"userId\", response.id);",
              "",
              "// Save username",
              "pm.environment.set(\"username\", response.username);",
              "",
              "// Print values in console for debugging",
              "console.log(response.accessToken);",
              "console.log(response.id);"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"username\": \"emilys\",\n  \"password\": \"emilyspass\"\n}",
          "options": {
            "raw": {
              "language": "json"
            }
          }
        },
        "url": {
          "raw": "https://dummyjson.com/auth/login",
          "protocol": "https",
          "host": [
            "dummyjson",
            "com"
          ],
          "path": [
            "auth",
            "login"
          ]
        }
      },
      "response": []
    },
